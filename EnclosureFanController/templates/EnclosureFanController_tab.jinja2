{% if plugin_EnclosureFanController_hardwareError %}
<div class="alert alert-error" id="enclosureHardwareError">
	<strong>{{ _('Hardware unavailable') }}</strong>
	<p>{{ plugin_EnclosureFanController_hardwareError }}</p>
</div>
{% else %}
<!-- Covers a tab that was already open when OctoPrint restarted and hit a
     hardware error - the block above only renders on page load/reload. -->
<div class="alert alert-error" data-bind="visible: hardwareError, text: hardwareError" style="display: none;"></div>
{% endif %}

<div class="well well-small enclosure-status-panel">
	<div class="enclosure-status-row">
		<div class="enclosure-status-block">
			<div class="enclosure-status-label">{{ _('Temperature') }}</div>
			<div class="enclosure-status-value" id="enclosureInfo" data-bind="attr: { title: 'Enclosure Temperature' }, html: enclosureTempValue"></div>
		</div>
		<div class="enclosure-status-block">
			<div class="enclosure-status-label">{{ _('Fan') }}</div>
			<div class="enclosure-status-value" id="enclosureFanState">
				<span data-bind="attr: { title: 'Fan State', class: fanBadgeClass }, text: fanBadgeText"></span>
			</div>
		</div>
	</div>
</div>
